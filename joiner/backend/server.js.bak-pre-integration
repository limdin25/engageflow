app.get('/api/profiles', (req, res) => {
  const rows = db.prepare(`
    SELECT p.*, 
      (SELECT COUNT(*) FROM join_queue WHERE profile_id = p.id) as queue_total,
      (SELECT COUNT(*) FROM join_queue WHERE profile_id = p.id AND status = 'joined') as joined_count
    FROM profiles p ORDER BY p.created_at DESC
  `).all();

  // Derive auth_method at runtime
  const profiles = rows.map(p => ({
    ...p,
    auth_method: p.cookie_json ? (p.password_enc ? 'cookies+password' : 'cookies') : (p.password_enc ? 'password_inactive' : 'none'),
  }));
  res.json(profiles);
});

app.post('/api/profiles', async (req, res) => {
  const { email, password, proxy, daily_cap, cookie_json } = req.body;
  if (!email) return res.status(400).json({ error: 'Email is required' });
  if (!password) return res.status(400).json({ error: 'Password is required' });

  const id = uuidv4();
  const password_enc = await bcrypt.hash(password, 10);

  db.prepare(`INSERT INTO profiles (id, email, password_enc, password_plain, cookie_json, proxy, daily_cap, auth_status)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?)`).run(

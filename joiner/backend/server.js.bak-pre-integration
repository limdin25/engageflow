      .run('connected', now, 'test_auth', req.params.id);
  } else {
    db.prepare('UPDATE profiles SET auth_status = ?, auth_error = ?, last_action_at = ?, last_action_type = ? WHERE id = ?')
      .run('expired', result.error, now, 'test_auth_failed', req.params.id);
  }
  writeLog(req.params.id, result.valid ? 'info' : 'error', 'test_auth', null, result.valid ? 'Auth valid' : `Auth failed: ${result.error}`);
  res.json(result);
});

app.post('/api/profiles/:id/paste-cookies', async (req, res) => {
  const profile = db.prepare('SELECT * FROM profiles WHERE id = ?').get(req.params.id);
  if (!profile) return res.status(404).json({ error: 'Not found' });

  const { cookies } = req.body; // raw cookie string or JSON array
  if (!cookies) return res.status(400).json({ error: 'No cookies provided' });

  let cookieJson;
  try {
    // Accept either JSON array or raw cookie string (from browser header)
    if (typeof cookies === 'string' && cookies.trim().startsWith('[')) {
      cookieJson = cookies.trim();
      JSON.parse(cookieJson); // validate
    } else if (Array.isArray(cookies)) {
      cookieJson = JSON.stringify(cookies);
    } else {
      // Raw cookie header string: "name=val; name2=val2"
      const pairs = cookies.split(';').map(p => p.trim()).filter(Boolean);
      const cookieArr = pairs.map(p => {
        const eq = p.indexOf('=');
        return {
          name: p.substring(0, eq),
          value: p.substring(eq + 1),
          domain: '.skool.com',
          path: '/'
        };
      });
      cookieJson = JSON.stringify(cookieArr);
    }
  } catch (e) {
    return res.status(400).json({ error: 'Invalid cookie format' });
  }

  // Validate cookies against Skool API
  const result = await validateCookies(cookieJson);
  const now = new Date().toISOString();

  if (result.valid) {
    db.prepare('UPDATE profiles SET cookie_json = ?, auth_status = ?, auth_error = NULL, last_login_at = ?, last_action_at = ? WHERE id = ?')
      .run(cookieJson, 'connected', now, now, req.params.id);
    writeLog(req.params.id, 'info', 'cookie_paste', null, 'Cookie paste successful — authenticated');
    res.json({ success: true, message: 'Cookies validated and stored' });
  } else {
    writeLog(req.params.id, 'error', 'cookie_paste_failed', null, `Cookie validation failed: ${result.error}`);
    res.status(401).json({ error: `Cookie validation failed: ${result.error}` });
  }
});

app.post('/api/profiles/:id/connect', async (req, res) => {
  const profile = db.prepare('SELECT * FROM profiles WHERE id = ?').get(req.params.id);
  if (!profile) return res.status(404).json({ error: 'Not found' });

  db.prepare('UPDATE profiles SET auth_status = ? WHERE id = ?').run('connecting', req.params.id);
  res.json({ success: true, message: 'Connecting...' });

  // Email/password from body or from stored profile
  const email = req.body.email || profile.email;
  const password = req.body.password || profile.password_plain;
  if (!password) {
    db.prepare('UPDATE profiles SET auth_status = ?, auth_error = ? WHERE id = ?')
      .run('error', 'No plaintext password available — re-add account or provide password', req.params.id);
    return;
  }

  connectProfile(req.params.id, email, password, profile.proxy).catch(console.error);
});

async function connectProfile(profileId, email, password, proxy) {
  db.prepare('UPDATE profiles SET auth_status = ? WHERE id = ?').run('connecting', profileId);
  writeLog(profileId, 'info', 'login_attempt', null, `Login attempt for ${email}`);

  const result = await loginAndStoreCookies(profileId, email, password, proxy);
  const now = new Date().toISOString();

  if (result.success) {
    db.prepare('UPDATE profiles SET cookie_json = ?, auth_status = ?, auth_error = NULL, last_login_at = ?, last_action_at = ? WHERE id = ?')
      .run(result.cookieJson, 'connected', now, now, profileId);
    writeLog(profileId, 'info', 'login_success', null, 'Login successful — cookies stored');
  } else {
    db.prepare('UPDATE profiles SET auth_status = ?, auth_error = ?, last_auth_error = ?, last_action_at = ? WHERE id = ?')
      .run('error', result.message, result.message, now, profileId);
    writeLog(profileId, 'error', 'login_failed', null, `Login failed: ${result.message}`);
  }
}


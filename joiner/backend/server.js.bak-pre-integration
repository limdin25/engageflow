    cookie_json ? 'connected' : 'disconnected'
  );

  writeLog(id, 'info', 'profile_created', null, `Profile created for ${email}`);

  // Auto-connect if no cookies provided
  if (!cookie_json) {
    connectProfile(id, email, password, proxy).catch(console.error);
  }

  res.json({ success: true, id });
});

app.post('/api/profiles/import-csv', async (req, res) => {
  const { csv_content } = req.body;
  if (!csv_content) return res.status(400).json({ error: 'csv_content required' });

  try {
    const records = parse(csv_content, { columns: true, skip_empty_lines: true, trim: true });
    const results = [];

    for (const row of records) {
      if (!row.email || !row.password) {
        results.push({ email: row.email, success: false, error: 'email and password required' });
        continue;
      }
      const id = uuidv4();
      const password_enc = await bcrypt.hash(row.password, 10);
      try {
        db.prepare(`INSERT INTO profiles (id, email, password_enc, cookie_json, proxy, daily_cap)
          VALUES (?, ?, ?, ?, ?, ?)`).run(
          id, row.email, password_enc, row.cookie_json || null, row.proxy || null, parseInt(row.daily_cap) || 50
        );
        results.push({ email: row.email, success: true, id });
        // Queue connect with delay
        setTimeout(() => connectProfile(id, row.email, row.password, row.proxy).catch(console.error), results.length * 5000);
      } catch (err) {
        results.push({ email: row.email, success: false, error: err.message });
      }
    }
    res.json({ success: true, results });
  } catch (err) {
    res.status(400).json({ error: err.message });
  }
});

app.patch('/api/profiles/:id', async (req, res) => {
  const { status, daily_cap, proxy, cookie_json, password } = req.body;
  const profile = db.prepare('SELECT * FROM profiles WHERE id = ?').get(req.params.id);
  if (!profile) return res.status(404).json({ error: 'Not found' });

  if (password) {
    const enc = await bcrypt.hash(password, 10);
    db.prepare('UPDATE profiles SET password_enc = ? WHERE id = ?').run(enc, req.params.id);
  }
  if (cookie_json !== undefined) {
    db.prepare('UPDATE profiles SET cookie_json = ?, auth_status = ? WHERE id = ?')
      .run(cookie_json, cookie_json ? 'connected' : 'disconnected', req.params.id);
  }

  db.prepare('UPDATE profiles SET status = COALESCE(?, status), daily_cap = COALESCE(?, daily_cap), proxy = COALESCE(?, proxy) WHERE id = ?')
    .run(status, daily_cap, proxy, req.params.id);

  res.json(db.prepare('SELECT * FROM profiles WHERE id = ?').get(req.params.id));
});

